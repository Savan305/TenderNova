generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  name      String?
  email     String     @unique
  password  String?
  image     String?
  plan      String     @default("Pro")
  createdAt DateTime   @default(now())
  tenders   Tender[]
  proposals Proposal[]
}

model Tender {
  id          String     @id @default(cuid())
  userId      String
  title       String
  fileName    String
  fileContent String
  status      String     @default("uploaded")
  summary     String?
  deadline    DateTime?
  budget      String?
  category    String?
  analysis    Json?
  eligibility Json?
  risks       Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals   Proposal[]
}

model Proposal {
  id        String   @id @default(cuid())
  userId    String
  tenderId  String
  title     String
  content   String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
}
