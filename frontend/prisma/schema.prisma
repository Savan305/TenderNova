generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(cuid())
  name      String?
  email     String     @unique
  password  String?
  image     String?
  plan      String     @default("Workspace")
  role      String     @default("user")
  disabled  Boolean    @default(false)
  company   String?
  phone     String?
  region    String?
  verified  Boolean    @default(false)
  onboarded Boolean    @default(false)
  lastLoginAt DateTime?
  lastSeenAt  DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @default(now()) @updatedAt
  tenders   Tender[]
  proposals Proposal[]
  workspaces Workspace[]
  messages  ChatMessage[]
  notifications Notification[]
  apiKeys   ApiKey[]
  apiUsages ApiUsage[]
  adminLogs AdminLog[]
  loginEvents LoginEvent[]
  jobs      ProcessingJob[]

  @@index([role])
  @@index([disabled])
  @@index([lastSeenAt])
}

model Tender {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String?
  title       String
  fileName    String
  fileContent String
  status      String     @default("uploaded")
  summary     String?
  deadline    DateTime?
  budget      String?
  category    String?
  analysis    Json?
  eligibility Json?
  risks       Json?
  sourceType  String     @default("pdf")
  aiScore     Int?
  successProbability Int?
  qualityRating String?
  errorMessage String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  proposals   Proposal[]
  analyses    TenderAnalysis[]
  messages    ChatMessage[]
  jobs        ProcessingJob[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([deadline])
}

model Proposal {
  id        String   @id @default(cuid())
  userId    String
  tenderId  String
  title     String
  content   String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenderId])
}

model Workspace {
  id              String   @id @default(cuid())
  userId          String
  name            String
  industry        String?
  businessCategory String?
  teamSize        String?
  preferredTenderSize String?
  sectorPreference String?
  capabilities    Json?
  services        Json?
  region          String?
  branding        Json?
  preferences     Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenders         Tender[]
}

model TenderAnalysis {
  id        String   @id @default(cuid())
  tenderId  String
  userId    String
  status    String   @default("completed")
  result    Json
  confidence Int?
  explanation String?
  createdAt DateTime @default(now())
  tender    Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([tenderId, createdAt])
  @@index([userId, createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  tenderId  String?
  role      String
  content   String
  citations Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tender    Tender?  @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenderId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  subject   String
  message   String
  status    String   @default("new")
  emailDelivered Boolean @default(false)
  emailError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email, createdAt])
}

model EmailOtp {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  codeHash  String
  purpose   String   @default("signup")
  expiresAt DateTime
  attempts  Int      @default(0)
  lastSentAt DateTime @default(now())
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  label     String
  encryptedValue String
  keyPreview String?
  status    String   @default("active")
  priority  Int      @default(100)
  requestCount Int   @default(0)
  failedCount  Int   @default(0)
  tokenUsage   Int   @default(0)
  tokenLimit   Int?
  rateLimitPerDay Int @default(1000)
  lastUsedAt DateTime?
  rotatedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages    ApiUsage[]

  @@index([provider, status, priority])
  @@index([userId, provider])
}

model ApiUsage {
  id        String   @id @default(cuid())
  userId    String
  apiKeyId  String?
  provider  String
  endpoint  String
  tokens    Int      @default(0)
  success   Boolean  @default(true)
  error     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKey    ApiKey?  @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([apiKeyId, createdAt])
  @@index([provider, createdAt])
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action])
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  provider  String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([success, createdAt])
  @@index([userId, createdAt])
}

model ProcessingJob {
  id        String   @id @default(cuid())
  userId    String
  tenderId  String?
  type      String
  status    String   @default("queued")
  progress  Int      @default(0)
  error     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tender    Tender?  @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, updatedAt])
  @@index([tenderId])
}
